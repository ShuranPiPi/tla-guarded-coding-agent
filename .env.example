# Copy this file to .env and fill in local secrets.
# Do not commit real API keys.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Provider selection: auto, openai, or gemini.
AGENT_PROVIDER=auto
AGENT_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-3.5-flash
AGENT_EMBED_MODEL=text-embedding-3-small

# Spec prompt mode: example or specification.
AGENT_SPEC_MODE=example
AGENT_MAX_SPEC_RETRIES=3
AGENT_MAX_CODE_RETRIES=3
TLA_TOOLS_JAR=tools/tla2tools.jar
